{
  "name": "ontology-diagram-editor",
  "displayName": "Ontology Diagram Editor",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ontology-diagram-editor.createOntologyDiagram",
    "onCommand:ontology-diagram-editor.modelTree.refresh",
    "onCommand:ontology-diagram-editor.modelTree.addOntology",
    "onCommand:ontology-diagram-editor.modelTree.removeOntology",
    "onCustomEditor:ontology-diagram-editor.diagramEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "odiagram",
        "aliases": [
          "Ontology Diagram",
          "odiagram"
        ],
        "extensions": [
          ".odiagram"
        ]
      }
    ],
    "commands": [
      {
        "command": "ontology-diagram-editor.createOntologyDiagram",
        "title": "Create Ontology Diagram"
      },
      {
        "command": "ontology-diagram-editor.modelTree.refresh",
        "title": "Refresh Model Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.addOntology",
        "title": "Add Ontology",
        "icon": "$(add)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.removeOntology",
        "title": "Remove Ontology",
        "icon": "$(remove)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ontology-diagram-editor",
          "title": "Ontology Diagram",
          "icon": "resources/ontology-diagram.svg"
        }
      ]
    },
    "views": {
      "ontology-diagram-editor": [
        {
          "id": "ontology-diagram-editor.modelTree",
          "name": "Model Tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ontology-diagram-editor.modelTree.addOntology",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation"
        },
        {
          "command": "ontology-diagram-editor.modelTree.refresh",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ontology-diagram-editor.modelTree.removeOntology",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyFile",
          "group": "inline"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ontology-diagram-editor.diagramEditor",
        "displayName": "Ontology Diagram Editor",
        "selector": [
          {
            "filenamePattern": "*.odiagram"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "dependencies": {
    "@maxgraph/core": "^0.23.0",
    "@rdfjs/types": "^2.0.1",
    "color-string": "^2.1.4",
    "dompurify": "^3.4.11",
    "rdf-parse": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
