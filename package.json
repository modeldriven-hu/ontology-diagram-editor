{
  "name": "ontology-diagram-editor",
  "displayName": "Ontology Diagram Editor",
  "description": "Create and edit ontology-backed diagrams from RDF and OWL files.",
  "version": "1.3.0",
  "publisher": "modeldriven-hu",
  "license": "Apache-2.0",
  "homepage": "https://github.com/modeldriven-hu/ontology-diagram-editor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/modeldriven-hu/ontology-diagram-editor.git"
  },
  "bugs": {
    "url": "https://github.com/modeldriven-hu/ontology-diagram-editor/issues"
  },
  "keywords": [
    "ontology",
    "RDF",
    "OWL",
    "diagram",
    "UML"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "odiagram",
        "aliases": [
          "Ontology Diagram",
          "odiagram"
        ],
        "extensions": [
          ".odiagram"
        ]
      }
    ],
    "commands": [
      {
        "command": "ontology-diagram-editor.createOntologyDiagram",
        "title": "Create Ontology Diagram"
      },
      {
        "command": "ontology-diagram-editor.modelTree.refresh",
        "title": "Refresh Diagram Dependencies",
        "icon": "$(refresh)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.filter",
        "title": "Filter Model Tree",
        "icon": "$(filter)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.showUnaddedItems",
        "title": "Show Unadded Ontology Elements",
        "icon": "$(list-filter)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.addOntology",
        "title": "Add Ontology",
        "icon": "$(add)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.removeOntology",
        "title": "Remove Ontology",
        "icon": "$(remove)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.openOntologyFile",
        "title": "Open Ontology File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.openOntologySource",
        "title": "Open Ontology Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "ontology-diagram-editor.modelTree.addAllToDiagram",
        "title": "Add All to Diagram",
        "icon": "$(add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ontology-diagram-editor",
          "title": "Ontology Diagram",
          "icon": "resources/ontology-diagram.svg"
        }
      ]
    },
    "views": {
      "ontology-diagram-editor": [
        {
          "id": "ontology-diagram-editor.modelTree",
          "name": "Model Tree"
        },
        {
          "id": "ontology-diagram-editor.properties",
          "name": "Properties",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "ontology-diagram-editor.createOntologyDiagram",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "ontology-diagram-editor.modelTree.filter",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation@1"
        },
        {
          "command": "ontology-diagram-editor.modelTree.showUnaddedItems",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation@2"
        },
        {
          "command": "ontology-diagram-editor.modelTree.addOntology",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation@3"
        },
        {
          "command": "ontology-diagram-editor.modelTree.refresh",
          "when": "view == ontology-diagram-editor.modelTree && ontologyDiagramEditor.hasDiagram",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "ontology-diagram-editor.modelTree.openOntologyFile",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyFile",
          "group": "navigation"
        },
        {
          "command": "ontology-diagram-editor.modelTree.openOntologySource",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyItem",
          "group": "navigation"
        },
        {
          "command": "ontology-diagram-editor.modelTree.removeOntology",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyFile",
          "group": "inline"
        },
        {
          "command": "ontology-diagram-editor.modelTree.addAllToDiagram",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyFile",
          "group": "navigation@1"
        },
        {
          "command": "ontology-diagram-editor.modelTree.addAllToDiagram",
          "when": "view == ontology-diagram-editor.modelTree && viewItem == ontologyGroup",
          "group": "navigation@1"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ontology-diagram-editor.diagramEditor",
        "displayName": "Ontology Diagram Editor",
        "selector": [
          {
            "filenamePattern": "*.odiagram"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\" && tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/carbon": "^1.2.24",
    "@iconify-json/mdi": "^1.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@rdfjs/types": "^2.0.1",
    "color-string": "^2.1.4",
    "elkjs": "^0.11.1",
    "lucide": "^1.22.0",
    "rdf-parse": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
